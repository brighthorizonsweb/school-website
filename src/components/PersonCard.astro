---
import type { Person } from '../lib/types';

interface Props {
	person: Person;
	index: number;
}

const { person, index } = Astro.props;

const GRADIENTS = [
	'from-sky-500 to-sky-700',
	'from-teal-500 to-teal-700',
	'from-violet-500 to-violet-700',
	'from-amber-500 to-amber-600',
	'from-rose-400 to-rose-600',
	'from-emerald-500 to-emerald-700',
	'from-indigo-500 to-indigo-700',
	'from-cyan-500 to-cyan-700',
];

const gradient = GRADIENTS[index % GRADIENTS.length];
const initials = person.name
	.split(' ')
	.map((n) => n[0])
	.join('')
	.slice(0, 2)
	.toUpperCase();
---

<details class="group border-b border-sky-50 last:border-b-0">
	<summary
		class="flex cursor-pointer list-none items-center gap-3 rounded-xl px-2 py-3 transition-colors hover:bg-sky-50/70 [&::-webkit-details-marker]:hidden"
	>
		<!-- Small avatar (collapsed) -->
		<div class="relative h-11 w-11 shrink-0 overflow-hidden rounded-lg">
			{
				person.headshotUrl ? (
					<img
						src={person.headshotUrl}
						alt={person.name}
						class="h-full w-full object-cover"
						loading="lazy"
					/>
				) : (
					<div
						class:list={[
							'flex h-full w-full items-center justify-center bg-gradient-to-br text-sm font-bold text-white',
							gradient,
						]}
					>
						{initials}
					</div>
				)
			}
		</div>

		<span class="min-w-0 flex-1 text-sm font-semibold leading-tight text-sky-950"
			>{person.name}</span
		>

		<!-- Chevron -->
		<svg
			class="h-4 w-4 shrink-0 text-sky-300 transition-transform duration-200 group-open:rotate-180"
			fill="none"
			viewBox="0 0 24 24"
			stroke="currentColor"
			stroke-width="2"
			aria-hidden="true"
		>
			<path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"></path>
		</svg>
	</summary>

	<!-- Expanded content -->
	<div class="px-2 pb-5 pt-2">
		<div class="flex gap-3">
			<!-- Larger avatar -->
			<div class="relative h-20 w-20 shrink-0 overflow-hidden rounded-lg">
				{
					person.headshotUrl ? (
						<img
							src={person.headshotUrl}
							alt={person.name}
							class="h-full w-full object-cover"
							loading="lazy"
						/>
					) : (
						<div
							class:list={[
								'flex h-full w-full items-center justify-center bg-gradient-to-br text-xl font-bold text-white',
								gradient,
							]}
						>
							{initials}
						</div>
					)
				}
			</div>

			<!-- Text -->
			<div class="min-w-0 flex-1">
				<p class="font-bold leading-tight text-sky-950">{person.name}</p>
				{
					person.title && (
						<p class="mt-0.5 text-xs font-semibold italic text-sky-700">{person.title}</p>
					)
				}
				{
					person.bio && (
						<p class="mt-2 text-xs leading-relaxed text-slate-600">{person.bio}</p>
					)
				}
			</div>
		</div>
	</div>
</details>
