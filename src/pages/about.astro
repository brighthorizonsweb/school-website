---
import Layout from '../layouts/Layout.astro';
import PageHeader from '../components/PageHeader.astro';
import CaptionedImage from '../components/CaptionedImage.astro';
import PersonCard from '../components/PersonCard.astro';
import { sanityClient } from 'sanity:client';
import { aboutPageQuery, facultyQuery, boardMembersQuery } from '../lib/queries';
import { withAboutPage, withFaculty, withBoardMembers } from '../lib/content';

const [rawAbout, rawFaculty, rawBoard] = await Promise.all([
	sanityClient.fetch(aboutPageQuery),
	sanityClient.fetch(facultyQuery),
	sanityClient.fetch(boardMembersQuery),
]);

const aboutPage = withAboutPage(rawAbout);
const faculty = withFaculty(rawFaculty);
const boardMembers = withBoardMembers(rawBoard);
---

<Layout title={aboutPage.pageTitle}>
	<PageHeader title={aboutPage.pageTitle ?? 'About'} subtitle={aboutPage.introParagraph} />

	<section class="relative overflow-hidden bg-stone-50 px-4 py-10 sm:px-6 lg:px-8">
		<!-- Decorative background shapes -->
		<div class="pointer-events-none absolute inset-0" aria-hidden="true">
			<div class="absolute left-[2%] top-12 h-28 w-28 rotate-6 rounded-2xl bg-teal-200/50"></div>
			<div class="absolute right-[3%] top-16 h-20 w-24 -rotate-8 rounded-2xl bg-sky-200/60"></div>
			<div
				class="absolute bottom-20 left-[8%] h-16 w-32 rotate-3 rounded-2xl bg-amber-200/50"
			></div>
			<div
				class="absolute bottom-10 right-[10%] h-24 w-16 -rotate-6 rounded-2xl bg-teal-300/30"
			></div>
			<div
				class="absolute right-[40%] top-4 h-12 w-12 rotate-12 rounded-xl bg-sky-300/30"
			></div>
			<div
				class="absolute bottom-[30%] left-[45%] h-10 w-20 -rotate-3 rounded-xl bg-violet-200/40"
			></div>
		</div>

		<div class="relative mx-auto max-w-7xl">
			<div class="grid grid-cols-1 gap-6 lg:grid-cols-[1fr_2fr_1fr]">

				<!-- ── LEFT: Faculty ── (order-2 so About content comes first on mobile) -->
				<aside class="order-2 lg:order-1">
					<div class="rounded-2xl border border-sky-100 bg-white p-5 shadow-sm">
						<div class="mb-4 border-b border-sky-50 pb-3">
							<p class="text-[10px] font-bold uppercase tracking-widest text-sky-700">
								Our Team
							</p>
							<h2 class="mt-0.5 text-lg font-extrabold tracking-tight text-sky-950">
								Faculty
							</h2>
						</div>
						<div class="space-y-0.5">
							{faculty.map((person, i) => <PersonCard person={person} index={i} />)}
						</div>
					</div>
				</aside>

				<!-- ── MIDDLE: About content (order-1 so it appears first on mobile) -->
				<div class="order-1 space-y-5 lg:order-2">
					<!-- Mission card -->
					<div class="rounded-2xl border border-sky-100 bg-white p-7 shadow-sm">
						<p class="text-[10px] font-bold uppercase tracking-widest text-sky-700">
							Why We Exist
						</p>
						<h2
							class="mt-1 text-xl font-extrabold tracking-tight text-sky-950 sm:text-2xl"
						>
							Mission
						</h2>
						<span class="accent-divider"></span>
						<p class="prose-bha mt-5 text-sm leading-relaxed text-slate-600 sm:text-base">
							{aboutPage.missionStatement}
						</p>
					</div>

					<!-- Section cards -->
					{
						aboutPage.sections?.map((section) => (
							<article class="overflow-hidden rounded-2xl border border-sky-100 bg-white shadow-sm">
								<div class="flex">
									<div class="w-1.5 shrink-0 bg-sky-800" />
									<div class="p-6 sm:p-7">
										<h3 class="text-lg font-bold text-sky-950">{section.heading}</h3>
										<p class="prose-bha mt-2 text-sm leading-relaxed text-slate-600">
											{section.body}
										</p>
										{section.images?.length ? (
											<div class="mt-5 grid gap-4 sm:grid-cols-2">
												{section.images.map((image) => (
													<CaptionedImage image={image} />
												))}
											</div>
										) : null}
									</div>
								</div>
							</article>
						))
					}
				</div>

				<!-- ── RIGHT: Board Members ── -->
				<aside class="order-3">
					<div class="rounded-2xl border border-sky-100 bg-white p-5 shadow-sm">
						<div class="mb-4 border-b border-sky-50 pb-3">
							<p class="text-[10px] font-bold uppercase tracking-widest text-sky-700">
								Governance
							</p>
							<h2 class="mt-0.5 text-lg font-extrabold tracking-tight text-sky-950">
								Board Members
							</h2>
						</div>
						<div class="space-y-0.5">
							{boardMembers.map((person, i) => <PersonCard person={person} index={i + faculty.length} />)}
						</div>
					</div>
				</aside>

			</div>
		</div>
	</section>
</Layout>
