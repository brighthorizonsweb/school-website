---
import Layout from '../layouts/Layout.astro';
import PageHeader from '../components/PageHeader.astro';
import { sanityClient } from 'sanity:client';
import { calendarEventsQuery } from '../lib/queries';
import { formatDisplayDate, withCalendarEvents } from '../lib/content';

const events = withCalendarEvents(await sanityClient.fetch(calendarEventsQuery));
---

<Layout title="Calendar">
	<PageHeader
		title="School Calendar"
		subtitle="Important dates and events throughout the year. Your browser will automatically scroll to the next upcoming date."
	/>

	<div class="relative overflow-hidden bg-stone-50">
		<div
			class="pointer-events-none absolute inset-0 bg-[radial-gradient(circle_at_top_right,rgba(14,165,233,0.06),transparent_45%),radial-gradient(circle_at_bottom_left,rgba(245,158,11,0.05),transparent_40%)]"
			aria-hidden="true"
		>
		</div>

		<section class="relative mx-auto max-w-3xl px-4 py-12 sm:px-6 lg:px-8">
			<ol class="space-y-5" id="calendar-list">
				{
					events.map((event) => (
						<li
							id={`event-${event._id}`}
							data-event-date={event.date}
							class="scroll-mt-28 flex overflow-hidden rounded-2xl border border-sky-100/80 bg-white shadow-sm"
						>
							<div class="w-1.5 shrink-0 bg-sky-700"></div>
							<div class="flex flex-1 flex-col justify-center px-5 py-5">
								<div class="flex flex-wrap items-baseline gap-x-3 gap-y-0.5">
									<time datetime={event.date} class="text-base font-bold text-sky-900">
										{formatDisplayDate(event.date)}
									</time>
									<span class="text-sm font-medium text-slate-400">{event.timeLabel}</span>
								</div>
								<p class="mt-1.5 text-base font-semibold text-slate-800">{event.title}</p>
								{event.description && (
									<p class="mt-1.5 text-sm leading-relaxed text-slate-500">{event.description}</p>
								)}
								{
									event.linkUrl && (
										<a
											href={event.linkUrl}
											class="mt-3 inline-flex min-h-10 items-center text-sm font-semibold text-sky-700 hover:text-sky-900"
											target={event.linkUrl.startsWith('http') ? '_blank' : undefined}
											rel={event.linkUrl.startsWith('http') ? 'noreferrer' : undefined}
										>
											{event.linkLabel ?? 'Learn more'} →
										</a>
									)
								}
							</div>
						</li>
					))
				}
			</ol>
		</section>
	</div>

	<script>
		function scrollToCurrentEvent() {
			const items = Array.from(document.querySelectorAll<HTMLElement>('[data-event-date]'));
			if (!items.length) return;

			const today = new Date();
			today.setHours(0, 0, 0, 0);

			const upcoming =
				items.find((item) => {
					const dateValue = item.dataset.eventDate;
					if (!dateValue) return false;
					const eventDate = new Date(`${dateValue}T12:00:00`);
					return eventDate >= today;
				}) ?? items[items.length - 1];

			upcoming.scrollIntoView({ behavior: 'smooth', block: 'center' });
		}

		if (document.readyState === 'loading') {
			document.addEventListener('DOMContentLoaded', scrollToCurrentEvent);
		} else {
			scrollToCurrentEvent();
		}
	</script>
</Layout>
