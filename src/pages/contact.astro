---
import Layout from '../layouts/Layout.astro';
import PageHeader from '../components/PageHeader.astro';
import { sanityClient } from 'sanity:client';
import { contactPageQuery, siteSettingsQuery } from '../lib/queries';
import { withContactPage, withSiteSettings } from '../lib/content';
import { DEFAULT_EMAIL, DEFAULT_PHONE, DEFAULT_PHONE_TEL } from '../lib/types';

const contactPage = withContactPage(await sanityClient.fetch(contactPageQuery));
const settings = withSiteSettings(await sanityClient.fetch(siteSettingsQuery));

const email = settings.adminEmail ?? DEFAULT_EMAIL;
const phone = settings.phoneNumber ?? DEFAULT_PHONE;
const phoneTel = phone.replace(/\D/g, '').length >= 10 ? `+1${phone.replace(/\D/g, '')}` : DEFAULT_PHONE_TEL;
---

<Layout title="Contact">
	<PageHeader title={contactPage.headline ?? 'Contact Us'} subtitle={contactPage.bodyText} />

	<section class="relative overflow-hidden bg-stone-50 px-4 py-16 sm:px-6 lg:px-8">
		<div class="pointer-events-none absolute inset-0" aria-hidden="true">
			<div class="absolute left-[5%] top-12 h-24 w-24 rotate-6 rounded-2xl bg-amber-200/50"></div>
			<div class="absolute right-[6%] top-16 h-32 w-20 -rotate-10 rounded-2xl bg-sky-200/50"></div>
			<div class="absolute bottom-10 left-[15%] h-20 w-28 rotate-4 rounded-2xl bg-teal-200/40"></div>
			<div class="absolute bottom-14 right-[18%] h-24 w-16 -rotate-6 rounded-2xl bg-amber-300/30"></div>
		</div>
		<div class="relative mx-auto max-w-2xl">
			<div class="overflow-hidden rounded-2xl border border-sky-100 bg-white shadow-sm">
				<div class="h-1.5 bg-sky-800"></div>
				<div class="grid gap-8 p-8 sm:grid-cols-2 sm:p-10">
					<div>
						<p class="text-xs font-bold uppercase tracking-widest text-sky-700">Email</p>
						<a
							href={`mailto:${email}`}
							class="mt-2 inline-flex min-h-12 items-center text-base font-semibold text-sky-800 hover:text-sky-950"
						>
							{email}
						</a>
					</div>
					<div>
						<p class="text-xs font-bold uppercase tracking-widest text-sky-700">Phone</p>
						<a
							href={`tel:${phoneTel}`}
							class="mt-2 inline-flex min-h-12 items-center text-base font-semibold text-sky-800 hover:text-sky-950"
						>
							{phone}
						</a>
						<p class="mt-1 text-xs text-slate-400">Placeholder for site preview</p>
					</div>
				</div>
			</div>
		</div>
	</section>
</Layout>
